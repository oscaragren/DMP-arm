    <collision><origin rpy="0 1.57 0" xyz="0 0 0"/>
      <geometry><mesh filename="arm/fullhand2/index3_2.stl" scale="-0.001 0.001 0.001"/></geometry>
    </collision>
  </link>

  <joint name="index_joint_3" type="fixed">
    <parent link="index_link_2"/>
    <child link="index_link_3"/>
    <origin rpy="0 0 0" xyz="-0.032 0 0"/> 
  </joint>

  <link name="index_link_3">
    <inertial>
        <mass value="0.02"/><inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
    <visual>
      <origin rpy="0 1.57 0" xyz="0 0 0"/>
