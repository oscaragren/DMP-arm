    <collision><geometry><mesh filename="arm/fullhand2/index3_1.stl" scale="-0.001 0.001 0.001"/></geometry></collision>
  </link>

  <joint name="index_joint_2" type="revolute">
    <parent link="index_link_1"/>
    <child link="index_link_2"/>
    <origin rpy="0 -1.57 0" xyz="0 0 -0.03"/> 
    <axis xyz="0 1 0"/>
    <dynamics damping="0.5" friction="0.5"/>
    <limit effort="1" lower="0.0" upper="1.5" velocity="2"/>
  </joint>

  <link name="index_link_2">
    <inertial>
        <mass value="0.02"/><inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
