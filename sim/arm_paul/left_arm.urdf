    <child link="middle_link_1"/>
    <origin rpy="0 1.57 0" xyz="-0.11 0.0095 0.012"/> 
    <axis xyz="0 1 0"/>
    <dynamics damping="0.5" friction="0.5"/>
    <limit effort="1" lower="0.0" upper="1.5" velocity="2"/>
  </joint>

  <link name="middle_link_1">
