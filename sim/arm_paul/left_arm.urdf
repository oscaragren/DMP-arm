    </collision>
  </link>

  <joint name="middle_joint_3" type="fixed">
    <parent link="middle_link_2"/>
    <child link="middle_link_3"/>
    <origin rpy="0 0 0" xyz="-0.03 0 0"/> 
  </joint>

  <link name="middle_link_3">
    <inertial>
        <mass value="0.02"/><inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.0001"/>
