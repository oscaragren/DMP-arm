    <origin rpy="-0.75 0 0" xyz="0.0 -0.035 -0.017"/> 
    <axis xyz="0 1 0"/>
    <dynamics damping="0.5" friction="0.5"/>
    <limit effort="1" lower="0.0" upper="1.5" velocity="2"/>
  </joint>

  <link name="ring_link_2">
